# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Kullanıcı adı + @ + domain = Auth’taki e-posta (npm run supabase:create-user ile otomatik oluşturulur)
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=lila.local
NEXT_PUBLIC_LOGIN_USERNAME=bakalım

# Script + gelişmiş hata mesajları — Project Settings → API → service_role (asla NEXT_PUBLIC yapma)
SUPABASE_SERVICE_ROLE_KEY=
